@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager NavigationManager
@inject GorevDurumService GorevServisi

<div class="page">
    <aside class="sidebar-shell">
        <NavMenu />
    </aside>

    <main class="workspace-main">
        <header class="top-row">
            <div class="top-row-breadcrumbs">
                <a class="breadcrumb-link" href="@UstKategoriBaglantisi">@UstKategori</a>
                <span class="breadcrumb-separator">/</span>
                <a class="breadcrumb-link breadcrumb-link-current" href="@SayfaBaglantisi">@SayfaBasligi</a>
            </div>

            <div class="top-row-meta">
                <button class="top-icon-button" @onclick="BildirimPenceresiniAc" title="Bildirim ayarlari">
                    <span class="toolbar-icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20" fill="none">
                            <path d="M10 3.5C7.7 3.5 6 5.3 6 7.5V9.4C6 10.1 5.7 10.8 5.2 11.3L4.3 12.2C3.8 12.7 4.2 13.5 4.9 13.5H15.1C15.8 13.5 16.2 12.7 15.7 12.2L14.8 11.3C14.3 10.8 14 10.1 14 9.4V7.5C14 5.3 12.3 3.5 10 3.5Z"></path>
                            <path d="M8.4 15.2C8.8 16 9.3 16.4 10 16.4C10.7 16.4 11.2 16 11.6 15.2"></path>
                        </svg>
                    </span>
                </button>

                <button class="top-icon-button" @onclick='() => AyarSekmesineGit("site")' title="Site ayarlari">
                    <span class="toolbar-icon" aria-hidden="true">
                        <svg viewBox="0 0 20 20" fill="none">
                            <path d="M10 4.1L11 2.8L12.7 3.3L13.1 5C13.5 5.2 13.9 5.4 14.2 5.7L15.9 5.2L17 6.5L16.1 8C16.2 8.4 16.3 8.8 16.3 9.2C16.3 9.6 16.2 10 16.1 10.4L17 11.9L15.9 13.2L14.2 12.7C13.9 13 13.5 13.2 13.1 13.4L12.7 15.1L11 15.6L10 14.3C9.6 14.3 9.2 14.3 8.8 14.3L7.8 15.6L6.1 15.1L5.7 13.4C5.3 13.2 4.9 13 4.6 12.7L2.9 13.2L1.8 11.9L2.7 10.4C2.6 10 2.5 9.6 2.5 9.2C2.5 8.8 2.6 8.4 2.7 8L1.8 6.5L2.9 5.2L4.6 5.7C4.9 5.4 5.3 5.2 5.7 5L6.1 3.3L7.8 2.8L8.8 4.1C9.2 4 9.6 4 10 4.1Z"></path>
                            <circle cx="9.4" cy="9.2" r="2.2"></circle>
                        </svg>
                    </span>
                </button>

                <span class="status-pill">@GorevServisi.AktifSprintAdi</span>

                <div class="user-menu-shell">
                    <button class="top-row-user user-menu-trigger" @onclick="KullaniciMenusunuDegistir" title="Kullanici menusu">
                        <span class="top-row-avatar">MY</span>
                    </button>

                    @if (KullaniciMenusuAcik)
                    {
                        <div class="user-menu-popover">
                            <div class="user-menu-profile">
                                <div class="user-menu-profile-avatar">MY</div>
                                <div>
                                    <strong>Razi Mert Yigit</strong>
                                    <small>SBNET\razimert.yigit</small>
                                </div>
                            </div>

                            <div class="user-menu-list">
                                <button class="user-menu-item" @onclick="ProfilPenceresiniAc">
                                    <span class="menu-item-icon" aria-hidden="true">
                                        <svg viewBox="0 0 20 20" fill="none">
                                            <circle cx="10" cy="7" r="3"></circle>
                                            <path d="M4.5 15.6C5.6 13.6 7.6 12.5 10 12.5C12.4 12.5 14.4 13.6 15.5 15.6"></path>
                                        </svg>
                                    </span>
                                    Profilim
                                </button>
                                <button class="user-menu-item" @onclick="BildirimPenceresiniAc">
                                    <span class="menu-item-icon" aria-hidden="true">
                                        <svg viewBox="0 0 20 20" fill="none">
                                            <path d="M10 3.5C7.7 3.5 6 5.3 6 7.5V9.4C6 10.1 5.7 10.8 5.2 11.3L4.3 12.2C3.8 12.7 4.2 13.5 4.9 13.5H15.1C15.8 13.5 16.2 12.7 15.7 12.2L14.8 11.3C14.3 10.8 14 10.1 14 9.4V7.5C14 5.3 12.3 3.5 10 3.5Z"></path>
                                            <path d="M8.4 15.2C8.8 16 9.3 16.4 10 16.4C10.7 16.4 11.2 16 11.6 15.2"></path>
                                        </svg>
                                    </span>
                                    Bildirim ayarlari
                                </button>
                                <button class="user-menu-item" @onclick='() => AyarSekmesineGit("ozellikler")'>
                                    <span class="menu-item-icon" aria-hidden="true">
                                        <svg viewBox="0 0 20 20" fill="none">
                                            <path d="M10 4.1L11 2.8L12.7 3.3L13.1 5C13.5 5.2 13.9 5.4 14.2 5.7L15.9 5.2L17 6.5L16.1 8C16.2 8.4 16.3 8.8 16.3 9.2C16.3 9.6 16.2 10 16.1 10.4L17 11.9L15.9 13.2L14.2 12.7C13.9 13 13.5 13.2 13.1 13.4L12.7 15.1L11 15.6L10 14.3C9.6 14.3 9.2 14.3 8.8 14.3L7.8 15.6L6.1 15.1L5.7 13.4C5.3 13.2 4.9 13 4.6 12.7L2.9 13.2L1.8 11.9L2.7 10.4C2.6 10 2.5 9.6 2.5 9.2C2.5 8.8 2.6 8.4 2.7 8L1.8 6.5L2.9 5.2L4.6 5.7C4.9 5.4 5.3 5.2 5.7 5L6.1 3.3L7.8 2.8L8.8 4.1C9.2 4 9.6 4 10 4.1Z"></path>
                                            <circle cx="9.4" cy="9.2" r="2.2"></circle>
                                        </svg>
                                    </span>
                                    Ozellikleri yonet
                                </button>
                                <button class="user-menu-item user-menu-item-with-arrow" @onclick="YardimaGit">
                                    <span class="menu-item-icon" aria-hidden="true">
                                        <svg viewBox="0 0 20 20" fill="none">
                                            <circle cx="10" cy="10" r="7"></circle>
                                            <path d="M7.9 7.8C8.1 6.7 8.9 6 10.1 6C11.4 6 12.2 6.8 12.2 7.9C12.2 8.9 11.5 9.3 10.8 9.8C10.1 10.2 9.7 10.6 9.7 11.6"></path>
                                            <circle cx="9.8" cy="13.8" r="0.7" fill="currentColor" stroke="none"></circle>
                                        </svg>
                                    </span>
                                    Yardim
                                </button>
                            </div>

                            <div class="user-menu-divider"></div>

                            <div class="user-menu-list">
                                <button class="user-menu-item" @onclick="FarkliKullaniciMesajiGoster">
                                    Farkli kullanici olarak oturum ac...
                                </button>
                                <button class="user-menu-item" @onclick="OturumuKapatMesajiGoster">
                                    Oturumu kapat
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(UstBildirimMesaji))
        {
            <div class="top-row-notice">@UstBildirimMesaji</div>
        }

        <article class="workspace-content">
            @Body
        </article>
    </main>
</div>

<KullaniciProfilModal AcikMi="@ProfilModalAcik" OnKapat="ProfilPenceresiniKapat" OnKaydetildi="ProfilKaydedildi" />
<BildirimAyarModal AcikMi="@BildirimModalAcik" OnKapat="BildirimPenceresiniKapat" OnKaydetildi="BildirimKaydedildi" />

<div id="blazor-error-ui" data-nosnippet>
    Beklenmeyen bir hata olustu.
    <a href="." class="reload">Yenile</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool KullaniciMenusuAcik;
    private bool ProfilModalAcik;
    private bool BildirimModalAcik;
    private string UstBildirimMesaji = string.Empty;

    private string GecerliYol =>
        NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('?', '#')[0].Trim('/');

    private string UstKategori =>
        GecerliYol switch
        {
            "" => "Genel Bakış",
            "gorevler" => "Genel Bakış",
            "gorevler/pano" => "Genel Bakış",
            "gorevler/liste" => "Genel Bakış",
            "sprint-yonetimi" => "Genel Bakış",
            "ayarlar" => "Ayarlar",
            _ => "Çalışma Alanı"
        };

    private string SayfaBasligi =>
        GecerliYol switch
        {
            "" => "Özet",
            "gorevler" => "İş Öğeleri",
            "gorevler/pano" => "Akış Tahtası",
            "gorevler/liste" => "Sorgular",
            "sprint-yonetimi" => "Sprint'ler",
            "ayarlar" => "Site Ayarları",
            _ => "Ekran"
        };

    private string UstKategoriBaglantisi =>
        GecerliYol switch
        {
            "ayarlar" => "/ayarlar",
            _ => "/"
        };

    private string SayfaBaglantisi =>
        GecerliYol switch
        {
            "" => "/",
            _ => $"/{GecerliYol}"
        };

    private void KullaniciMenusunuDegistir()
    {
        KullaniciMenusuAcik = !KullaniciMenusuAcik;
        UstBildirimMesaji = string.Empty;
    }

    private void AyarSekmesineGit(string sekme)
    {
        KullaniciMenusuAcik = false;
        UstBildirimMesaji = "Ayarlar merkezi acildi.";
        NavigationManager.NavigateTo($"/ayarlar?sekme={sekme}");
    }

    private void ProfilPenceresiniAc()
    {
        KullaniciMenusuAcik = false;
        ProfilModalAcik = true;
        UstBildirimMesaji = string.Empty;
    }

    private Task ProfilPenceresiniKapat()
    {
        ProfilModalAcik = false;
        return Task.CompletedTask;
    }

    private Task ProfilKaydedildi(string mesaj)
    {
        UstBildirimMesaji = mesaj;
        return Task.CompletedTask;
    }

    private void BildirimPenceresiniAc()
    {
        KullaniciMenusuAcik = false;
        BildirimModalAcik = true;
        UstBildirimMesaji = string.Empty;
    }

    private Task BildirimPenceresiniKapat()
    {
        BildirimModalAcik = false;
        return Task.CompletedTask;
    }

    private Task BildirimKaydedildi(string mesaj)
    {
        UstBildirimMesaji = mesaj;
        return Task.CompletedTask;
    }

    private void YardimaGit()
    {
        KullaniciMenusuAcik = false;
        UstBildirimMesaji = "Yardim merkezi giris noktasi ayarlar bolumune baglandi.";
        NavigationManager.NavigateTo("/ayarlar?sekme=site");
    }

    private void FarkliKullaniciMesajiGoster()
    {
        KullaniciMenusuAcik = false;
        UstBildirimMesaji = "Farkli kullanici ile giris akis eklendiginde burada acilacak.";
    }

    private void OturumuKapatMesajiGoster()
    {
        KullaniciMenusuAcik = false;
        UstBildirimMesaji = "Oturum kapatma akis kimlik dogrulama modulunden sonra baglanacak.";
    }

    protected override void OnInitialized()
    {
        GorevServisi.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        GorevServisi.OnChange -= StateHasChanged;
    }
}
